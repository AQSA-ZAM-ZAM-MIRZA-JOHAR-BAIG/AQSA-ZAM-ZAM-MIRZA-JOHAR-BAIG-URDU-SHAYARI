2:Td5b,{"@context":"https://schema.org","@type":"ItemList","name":"Legal Blogs by AQSA ZAM ZAM MIRZA JOHAR BAIG","itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"BlogPosting","headline":"Fundamental Rights in India: A Deep Dive into Part III of the Constitution","description":"An analytical exploration of Articles 12 to 35 of the Indian Constitution — the Fundamental Rights chapter. This article traces the evolution of rights jurisprudence from A.K. Gopalan to the expansive interpretation in Maneka Gandhi v. Union of India, and examines what \"life and personal liberty\" truly means in 2026.","author":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"},"datePublished":"March 2026","publisher":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"}}},{"@type":"ListItem","position":2,"item":{"@type":"BlogPosting","headline":"How to Write a Legal Research Paper: A Step-by-Step Guide for Law Students","description":"From identifying a legal question to constructing arguments with case law, statutes, and secondary sources — this guide distills the methodology AQSA ZAM ZAM MIRZA JOHAR BAIG uses for her Legal Research specialization at PDLC Amravati. Covers IRAC method, citation formats, and avoiding plagiarism.","author":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"},"datePublished":"February 2026","publisher":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"}}},{"@type":"ListItem","position":3,"item":{"@type":"BlogPosting","headline":"Understanding the Indian Evidence Act, 1872: Key Provisions Every Law Student Must Know","description":"A structured breakdown of the Indian Evidence Act 1872 — covering relevancy of facts (Section 6–55), oral and documentary evidence (Sections 59–90), and the evolving law on electronic records (Section 65B). Includes analysis of landmark decisions of the Supreme Court and High Courts on admissibility.","author":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"},"datePublished":"January 2026","publisher":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"}}},{"@type":"ListItem","position":4,"item":{"@type":"BlogPosting","headline":"Women's Rights in Muslim Personal Law: After Triple Talaq and Beyond","description":"A critical assessment of how Muslim Personal Law intersects with constitutional guarantees after the landmark Shayara Bano v. Union of India (2017) verdict abolishing instant Triple Talaq. Explores Section 125 CrPC maintenance, Mehr rights, divorce by mutual consent (Khul), and what legislative reform is still needed.","author":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"},"datePublished":"December 2025","publisher":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"}}},{"@type":"ListItem","position":5,"item":{"@type":"BlogPosting","headline":"The Intersection of Language and Law: Urdu in Indian Courts and Legal Discourse","description":"A unique socio-legal essay exploring how Urdu — once the language of the Mughal courts and later of legal pleadings in undivided India — has shaped Indian legal terminology. From 'fatwas' to 'istighasa', this article traces the rich Urdu-legal lexicon and its contemporary relevance in courts of Uttar Pradesh, Maharashtra, and Telangana.","author":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"},"datePublished":"November 2025","publisher":{"@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG"}}}]}6:T48b,{"@context":"https://schema.org","@type":"Person","name":"AQSA ZAM ZAM MIRZA JOHAR BAIG","alternateName":["Aqsa Mirza","AqsA Zam Zam Mirza","Aqsa Johar Baig","AqsA Zam Zam"],"jobTitle":"Law Student & Legal Researcher","description":"AQSA ZAM ZAM MIRZA JOHAR BAIG is a Law Student at PDLC Amravati (Prakash Law College), specializing in Legal Research. She is also a Technical Writer and Urdu Shayari Poet based in Amravati, Maharashtra, India.","knowsAbout":["Legal Research","Legal Drafting","Constitutional Law","Technical Writing","Urdu Shayari","Urdu Literature","Indian Penal 